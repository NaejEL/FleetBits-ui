# Fleet UI — environment variables
# Copy to .env and fill in for local development.
# NEVER commit .env to git.

# -----------------------------------
# Flask secret key (session cookies)
# Generate: openssl rand -base64 32
# -----------------------------------
SECRET_KEY=dev-flask-secret-change-in-production

# -----------------------------------
# Fleet API base URL
# -----------------------------------
FLEET_API_URL=http://localhost:8000

# -----------------------------------
# Grafana base URL (for iframe panel embeds)
# -----------------------------------
GRAFANA_URL=http://localhost:3000

# -----------------------------------
# Semaphore base URL (shown in nav header as external link)
# -----------------------------------
SEMAPHORE_URL=http://localhost:3001

# -----------------------------------
# Fleet domain (used to build Grafana subdomain URL)
# -----------------------------------
FLEET_DOMAIN=localhost

# -----------------------------------
# Application environment
# -----------------------------------
FLEET_ENV=development

# -----------------------------------
# Admin credentials for initial setup
# These seed the DB on first run; change immediately after.
# -----------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately
