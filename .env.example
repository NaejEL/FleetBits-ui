# Fleet UI — environment variables
# Copy to .env and fill in for local development.
# NEVER commit .env to git.

# -----------------------------------
# Flask secret key (session cookies)
# Generate: openssl rand -base64 32
# -----------------------------------
SECRET_KEY=CHANGE_ME_GENERATED_SECRET

# -----------------------------------
# Fleet API base URL
# -----------------------------------
FLEET_API_URL=http://localhost:8000

# -----------------------------------
# Grafana base URL (for iframe panel embeds)
# -----------------------------------
GRAFANA_URL=http://localhost:3000

# -----------------------------------
# Semaphore base URL (shown in nav header as external link)
# -----------------------------------
SEMAPHORE_URL=http://localhost/semaphore

# -----------------------------------
# Fleet domain (used to build Grafana subdomain URL)
# -----------------------------------
FLEET_DOMAIN=localhost

# -----------------------------------
# Application environment
# -----------------------------------
FLEET_ENV=development
FLASK_DEBUG=true
